{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generar Lexer",
      "type": "shell",
      "command": "C:/Program Files/Java/jdk-23/bin/java.exe",
      "args": [
        "-jar",
        "lib/jflex-full-1.9.1.jar",
        "src/ParserLexer/Lexer.flex",
        "-d",
        "src/AnalizadorSintactico"
      ],
      "group": "build"
    },
    {
      "label": "Generar Parser",
      "type": "shell",
      "command": "C:/Program Files/Java/jdk-23/bin/java.exe",
      "args": [
        "-jar",
        "lib/java-cup-11b.jar",
        "-parser",
        "Parser",
        "-symbols",
        "sym",
        "-destdir",
        "src/AnalizadorSintactico",
        "src/ParserLexer/Parser.cup"
      ],
      "group": "build"
    },
    {
      "label": "Compilar Java",
      "type": "shell",
      "command": "C:/Program Files/Java/jdk-23/bin/javac.exe",
      "args": [
        "-d", "bin",
        "-cp", "'lib/*;src'",
        "src/AnalizadorSintactico/*.java",
        "src/Compilador/*.java"
      ],
      "group": "build"
    },
    {
      "label": "Probar Parser",
      "type": "shell",
      "command": "C:/Program Files/Java/jdk-23/bin/java.exe",
      "args": [
        "-cp",
        "bin;lib/java-cup-11b-runtime.jar;lib/java-cup-11b.jar;lib/jflex-full-1.9.1.jar",
        "Compilador.TestCompilador",
        "parse",
        "src/Test/ejemplo_valido_minimo.txt"
      ],
      "dependsOn": [
        "Generar Lexer",
        "Generar Parser",
        "Compilar Java"
      ],
      "dependsOrder": "sequence",
      "group": "test"
    },
    {
      "label": "Build Completo",
      "dependsOn": [
        "Generar Lexer",
        "Generar Parser",
        "Compilar Java",
        "Probar Parser"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}